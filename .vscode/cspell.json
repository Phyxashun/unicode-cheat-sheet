{
  // ~ FILE-PATH: .vscode/cspell.json
  // Add this to .vscode/settings.json to ensure the custom dictionary is recognized:
  // "cSpell.customDictionaries": {
  //   "cspell-dictionary": {
  //     "name": "cspell-dictionary",
  //     "path": "${workspaceFolder:unicode-cheat-sheet}/.vscode/cspell-dictionary.txt",
  //     "addWords": true,
  //     "scope": "workspace"
  //   }
  // }
  //
  // Also add this to .vscode/extensions.json to enable pre-built technical dictionaries:
  // "cSpell.enabledDictionaries": [
  //    "en_US",
