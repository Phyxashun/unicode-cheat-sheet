  "version": "0.2",
  "language": "en",
  "words": [
    // Add any specific words you want to include here
  ],
  "flagWords": [
    //
  ],
  "ignoreWords": [
    // Add any specific words you want to ignore here
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/ALL/**",
    "**/dist/**",
    "**/build/**",
    "**/.vscode/**",
    "**/.git/**"
  ],
  "maxNumberOfProblems": 10000,
  "minWordLength": 4,
  "allowCompoundWords": false,
  "dictionaries": ["cspell-dictionary"],
  "dictionaryDefinitions": [
    {
      "name": "cspell-dictionary",
      "path": "./cspell-dictionary.txt",
      "addWords": true,
      "scope": "workspace"
    }
  ],
  "ignoreRegExpList": [
    //
  ],
  "includeRegExpList": [
    //
  ],
  "patterns": [
    // Define any custom patterns if needed
  ],
  "languageSettings": [
    // https://cspell.org/docs/Configuration/language-settings#languagesettings
  ],
  "import": [
    // Import other cspell configuration files if necessary
  ]
}
