{
  // ~ file-path: .vscode/settings.json
  // ============================================================================================
  //      ⚙️ GENERAL SETTINGS
  // ============================================================================================
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "files.trimTrailingWhitespaceInRegexAndStrings": false,
  "files.associations": {
    "*.json": "jsonc",
    "*.editorconfig": "editorconfig",
    "*.psm1": "powershell",
    "*.psd1": "powershell",
    "*.ps1": "powershell"
  },
  // ============================================================================================
  //      🎨 WORKBENCH & APPEARANCE
  // ============================================================================================
  "workbench.colorTheme": "Theme Darker",
  "workbench.iconTheme": "vs-seti",
  "workbench.productIconTheme": "material-product-icons",
  "workbench.panel.defaultLocation": "right",
  // ============================================================================================
  //      📝 EDITOR CORE SETTINGS
  // ============================================================================================
  "editor.fontFamily": "'JetBrainsMono NFM Regular'",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.4,
  "editor.fontLigatures": true,
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": false,
  "editor.tabSize": 2,
  "editor.indentSize": 2,
  "editor.inlineSuggest.enabled": true,
  "editor.suggest.preview": true,
  "editor.tabCompletion": "on",
  "editor.showDeprecated": true,
  "editor.autoIndent": "full",
  "editor.wordWrapColumn": 100,
  "editor.rulers": [100],
  "editor.semanticHighlighting.enabled": true,
  "editor.semanticTokenColorCustomizations": {
    "enabled": true
  },
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.defaultModel": "indentationModel",
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.guides.highlightActiveBracketPair": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.indentation": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "always",
    "source.addMissingImports": "always"
  },
  "editor.wordWrap": "on",
  "editor.defaultFoldingRangeProvider": "EditorConfig.EditorConfig",
  "editor.foldingStrategy": "auto",
  "editor.folding": true,
  "editor.detectIndentation": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnType": false,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "files.autoSave": "onFocusChange",
  // ============================================================================================
  //      🖥️ TERMINAL SETTINGS
  // ============================================================================================
  "terminal.integrated.fontFamily": "'JetBrainsMono NFM Regular'",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.lineHeight": 1,
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.profiles.linux": {
    "fish-host": {
      "path": "host-spawn",
      "args": ["fish"],
      "icon": "terminal-linux"
    }
  },
  "terminal.integrated.defaultProfile.linux": "fish",
  //*********************************************************************************************
  //*
  //*      💻 LANGUAGE SPECIFIC SETTINGS
  //*
  //*********************************************************************************************
  // ============================================================================================
  //      ⚙️ CSS SETTINGS
  // ============================================================================================
  "css.styleSheets": ["node_modules/bulma/css/bulma.min.css", "src/**/*.css"],
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",
  "tailwindTranspiler.savePath": "public/css",
  // ============================================================================================
  //      ⚙️ JAVASCRIPT/TYPESCRIPT SETTINGS
  // ============================================================================================
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "betterTypeScriptErrors.prettify": true,
  "js/ts.inlayHints.parameterNames.enabled": "all",
  "js/ts.inlayHints.variableTypes.enabled": true,
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.format.semicolons": "insert",
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.referencesCodeLens.enabled": true,
  "js/ts.suggest.autoImports": false,
  "js/ts.updateImportsOnPaste.enabled": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.suggest.paths": false,
  "js/ts.suggestionActions.enabled": true,
  "js/ts.tsserver.log": "off",
  "js/ts.tsserver.useSyntaxServer": "always",
  "extensions.experimental.affinity": {
    "better-ts-errors.better-ts-errors": 1
  },
  "editor.experimental.preferTreeSitter.typescript": true,
  "js/ts.tsserver.experimental.enableProjectDiagnostics": true,
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // ============================================================================================
  //      ⚙️ MARKDOWN SETTINGS
  // ============================================================================================
  "markdown.validate.enabled": true,
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // ============================================================================================
  //      ⚙️ JSON/JSONC SETTINGS
  // ============================================================================================
  "json.schemaDownload.enable": false,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // ============================================================================================
  //      ⚙️ BUN SETTINGS
  // ============================================================================================
  "bun.runtime": "%USERPROFILE%/.bun/bin/bun",
  "bun.debugTerminal.enabled": true,
  "bun.debugTerminal.stopOnEntry": false,
  "bun.test.filePattern": "**/*{.test.,.spec.,_test_,_spec_}{js,ts,tsx,jsx,mts,cts,cjs,mjs}",
  "bun.test.customScript": "bun test",
  // ============================================================================================
  //      ⚙️ GIT SETTINGS
  // ============================================================================================
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",
  // ============================================================================================
  //      ⚙️ POWERSHELL SETTINGS
  // ============================================================================================
  // Integrated Console Settings
  "powershell.integratedConsole.focusConsoleOnExecute": false,
  "powershell.integratedConsole.suppressStartupBanner": false,
  // Code Formatting Settings (some example defaults)
  "powershell.codeFormatting.preset": "Stroustrup",
  "powershell.codeFormatting.openBraceOnSameLine": true,
  "powershell.codeFormatting.newLineAfterOpenBrace": true,
  // Pester Settings
  "powershell.pester.useLegacyCodeLens": false,
  // Script Analysis & Linting Settings
  "powershell.scriptAnalysis.enable": true,
  "powershell.scriptAnalysis.settingsPath": "",
  "[powershell]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  //*********************************************************************************************
  //*
  //*         ➕ EXTENSION-SPECIFIC SETTINGS
  //*
  //*********************************************************************************************
  // ============================================================================================
  //      ⚙️ TOML AND EDITORCONFIG SETTINGS
  // ============================================================================================
  "[toml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[editorconfig]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // ============================================================================================
  //      ⚙️ PRETTIER/ESLINT SETTINGS
  // ============================================================================================
  "prettier.useEditorConfig": true,
  "eslint.format.enable": true,
  "eslint.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.codeAction.showDocumentation": {
    "enable": true
  },
  "eslint.codeAction.disableRuleComment": {
    "enable": true,
    "location": "sameLine"
  },
  "eslint.options": {
    "overrideConfigFile": "eslint.config.ts"
  },
  // ============================================================================================
  //      ⚙️ REGION FOLDING SETTINGS
  // ============================================================================================
  "maptz.regionfolder": {
    "[powershell]": {
      "foldStart": "#&region [NAME]",
      "foldStartRegex": "^[\\s]*#&?[\\s]*region[\\s]*(.*)",
      "foldEnd": "#&endregion",
      "foldEndRegex": "^[\\s]*#&?[\\s]*endregion",
      "foldDefinitions": [
        {
          "foldStart": "#region [NAME]",
          "foldStartRegex": "^[\\s]*#?[\\s]*region[\\s]*(.*)",
          "foldEnd": "#endregion",
          "foldEndRegex": "^[\\s]*#?[\\s]*endregion"
        }
      ]
    }
  },
  // ============================================================================================
  //      ⚙️ BETTER COMMENTS SETTINGS
  // ============================================================================================
  "better-comments.multilineComments": true,
  "better-comments.highlightPlainText": false,
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF6E6E",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    },
    {
      "tag": "?",
      "color": "#8be9fd",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "//",
      "color": "#50fa7b",
      "strikethrough": true,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "todo",
      "color": "#ffb86c",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "fixme",
      "color": "#6272a4",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "fixit",
      "color": "#6272a4",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "fix",
      "color": "#6272a4",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "bug",
      "color": "#ff5555",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "*",
      "color": "#ff79c6",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false
    },
    {
      "tag": "&",
      "color": "#D6ACFF",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": true
    },
    {
      "tag": "region",
      "color": "#BD93F9",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "endregion",
      "color": "#BD93F9",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    }
  ],
  // ============================================================================================
  //      ⚙️ INDENT RAINBOW SETTINGS
  // ============================================================================================
  "indentRainbow.indicatorStyle": "classic",
  "indentRainbow.lightIndicatorStyleLineWidth": 1,
  "indentRainbow.colorOnWhiteSpaceOnly": true,
  "indentRainbow.updateDelay": 100,
  "indentRainbow.ignoreErrorLanguages": ["haskell"],
  "indentRainbow.errorColor": "rgba(128,32,32,0.6)",
  "indentRainbow.tabmixColor": "rgba(128,32,96,0.6)",
  "indentRainbow.colors": [
    "rgba(255,255,64,0.07)",
    "rgba(127,255,127,0.07)",
    "rgba(255,127,255,0.07)",
    "rgba(79,236,236,0.07)"
  ],
  // ============================================================================================
  //      🎨 COLORIZE SETTINGS
  // ============================================================================================
  "colorize.decoration_type": "background", // "background", "underline", "outline", "dot", "square-dot"
  "colorize.enable_search_variables": true,
  "colorize.hide_current_line_decorations": true,
  "colorize.colorized_colors": [
    "HEXA", // hexadecimal colors: #RGB, #RGBA, #RRGGBB, #RRGGBBAA, 0xRGB, 0xRGBA, 0xRRGGBB or 0xRRGGBBAA
    "ARGB", // argb colors: #RGB, #ARGB, #RRGGBB or #AARRGGBB
    "RGB", // rgb colors: rgb(r,g,b) or rgba(r,g,b,a)
    "HSL", // HSL colors
    //"BROWSERS_COLORS", // native browser's colors like white, red, blue...
    "OKLAB", // oklab colors
    "OKLCH" // oklch colors
  ],
  "colorize.languages": [
    "css",
    "scss",
    "sass",
    "less",
    "html",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "json",
    "jsonc",
    "toml",
    "python",
    "java",
    "powershell",
    "ps1",
    "psd1",
    "markdown",
    "md",
    "mdx"
  ],
  "colorize.include": ["**/src/**", "*.html"],
  "colorize.exclude": ["**/node_modules/**", "**/ALL/**"],
  "colorize.colorized_variables": ["LESS"],
  "cSpell.words": [
    "AUTOINCREMENT",
    "BLOCKEND",
    "BLOCKNAME",
    "BLOCKSTART",
    "NAMESLIST"
  ],
  // ~ FILE-PATH: .vscode/settings.json
  //
  "highlight.decorations": {},
  "highlight.regexFlags": "gim",
  "highlight.regexes": {
    "((\/\/)(\\s{1}~\\s{1})(file-path\\s{0}:)(\\s{1}.*\\s?))(\\r?\\n)": {
      "regexFlags": "gi",
      "decorations": [
        {
          //* Group 1: the entire match
          "borderRadius": "4px",
          "border": "1px solid #FF9E64",
          "backgroundColor": "#000"
        },
        {
          //* Group 2: (//) comment slashes
          "color": "#00FF85"
        },
        {
          //* Group 3: (~) symbol
          "color": "#00FF85"
        },
        {
          //* Group 4: (file-path) tag
          "fontWeight": "bold",
          "color": "#FF007F"
        },
        {
          //* Group 5: (.*) the actual file path text
          "fontWeight": "bold",
          "color": "#BB86FC",
          "border": "none",
          "after": {
            "contentText": " "
          }
        },
        {
          //* Group 6: (line break)
          "before": {
            "color": "#00FF85",
            "contentText": " ~ //",
            "paddingLeft": "4px"
          }
        }
      ]
    }
  }
}
